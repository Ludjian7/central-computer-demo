# ==============================
# Central Computer — Environment
# ==============================

# Server
NODE_ENV=production

# Railway injects PORT automatically — do not set manually
# PORT=3000

# REQUIRED: JWT secret key (min. 32 random characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=ganti-dengan-string-acak-yang-panjang-dan-aman

# Optional: Path to SQLite database file
# Default: ./database.sqlite (relative to project root)
# DB_PATH=./database.sqlite
