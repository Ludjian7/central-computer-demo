# ==============================
# Central Computer — Environment (Vercel Postgres)
# ==============================

NODE_ENV=production
JWT_SECRET=your_secret_here

# Vercel Postgres Connection (Get these from Vercel Dashboard -> Storage -> Settings)
# Use POSTGRES_PRISMA_URL for indexed connections (pooling)
POSTGRES_PRISMA_URL="postgres://..."

# Use POSTGRES_URL_NON_POOLING for direct migration/prisma push
POSTGRES_URL_NON_POOLING="postgres://..."
